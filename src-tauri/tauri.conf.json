{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LepoProxy",
  "version": "0.1.0",
  "identifier": "com.lepoproxy.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LepoProxy",
        "width": 340,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "license": "Apache-2.0",
    "licenseFile": "LICENSE.txt",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "compression": "lzma",
        "displayLanguageSelector": true,
        "languages": [
          "SimpChinese",
          "TradChinese",
          "English"
        ],
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installerHooks": "hooks.nsh",
        "sidebarImage": "icons/sidebar.bmp"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
